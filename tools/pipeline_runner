#!/usr/bin/env bash
# tools/pipeline_runner - CLI tool for executing Tempo data pipelines
# Used in GitHub Actions and local development.
#
# Usage:
#   ./tools/pipeline_runner --pipeline augment --output data/
#   ./tools/pipeline_runner --list
#   ./tools/pipeline_runner --help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PIPELINES_DIR="${PROJECT_ROOT}/pipelines"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

log_info()  { echo -e "${GREEN}[INFO]${NC} $*"; }
log_warn()  { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*" >&2; }

usage() {
    cat <<EOF
Tempo Pipeline Runner

Usage:
    $(basename "$0") --pipeline <name> [--output <dir>]
    $(basename "$0") --list
    $(basename "$0") --help

Options:
    -p, --pipeline <name>   Pipeline to run (e.g., augment)
    -o, --output <dir>      Output directory (default: data/)
    -l, --list              List available pipelines
    -h, --help              Show this help

Environment Variables:
    AUGMENT_API_URL         Augment Code API URL
    AUGMENT_API_TOKEN       Augment Code API token
    TEMPO_LOG_LEVEL         Log level (default: INFO)

Examples:
    $(basename "$0") --pipeline augment --output data/
    $(basename "$0") --list
EOF
}

ensure_poetry() {
    if ! command -v poetry &>/dev/null; then
        log_warn "Poetry not found. Attempting install via pip..."
        pip install poetry 2>/dev/null || {
            log_error "Failed to install poetry. Please install it: https://python-poetry.org/docs/"
            exit 1
        }
    fi
}

install_deps() {
    log_info "Installing pipeline dependencies..."
    cd "${PIPELINES_DIR}"
    poetry install --no-interaction --quiet
    cd "${PROJECT_ROOT}"
}

run_pipeline() {
    local pipeline="$1"
    local output="$2"

    log_info "Running pipeline: ${pipeline}"
    log_info "Output directory: ${output}"

    cd "${PIPELINES_DIR}"
    poetry run tempo-pipeline run --pipeline "${pipeline}" --output "${PROJECT_ROOT}/${output}"
    local exit_code=$?
    cd "${PROJECT_ROOT}"

    if [ ${exit_code} -eq 0 ]; then
        log_info "Pipeline '${pipeline}' completed successfully"
    else
        log_error "Pipeline '${pipeline}' failed with exit code ${exit_code}"
        exit ${exit_code}
    fi
}

list_pipelines() {
    log_info "Available pipelines:"
    cd "${PIPELINES_DIR}"
    poetry run tempo-pipeline list
    cd "${PROJECT_ROOT}"
}

# Parse arguments
PIPELINE=""
OUTPUT="data"
ACTION="run"

while [[ $# -gt 0 ]]; do
    case "$1" in
        -p|--pipeline) PIPELINE="$2"; shift 2 ;;
        -o|--output)   OUTPUT="$2"; shift 2 ;;
        -l|--list)     ACTION="list"; shift ;;
        -h|--help)     usage; exit 0 ;;
        *)             log_error "Unknown option: $1"; usage; exit 1 ;;
    esac
done

# Execute
ensure_poetry
install_deps

case "${ACTION}" in
    list)
        list_pipelines
        ;;
    run)
        if [ -z "${PIPELINE}" ]; then
            log_error "Pipeline name required. Use --pipeline <name>"
            usage
            exit 1
        fi
        run_pipeline "${PIPELINE}" "${OUTPUT}"
        ;;
esac
