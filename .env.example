# Tempo Agent Configuration

# Backend
TEMPO_PORT=4000
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
PHX_HOST=localhost

# Dashboard
DASHBOARD_PORT=4200

# Data sources
AUGMENT_API_URL=https://api.augmentcode.com
AUGMENT_API_TOKEN=

# IAMQ (Inter-Agent Message Queue)
IAMQ_HTTP_URL=http://127.0.0.1:18790
IAMQ_WS_URL=ws://127.0.0.1:18793/ws
IAMQ_AGENT_ID=tempo_agent
IAMQ_HEARTBEAT_MS=300000
IAMQ_POLL_MS=60000
