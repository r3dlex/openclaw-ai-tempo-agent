# =============================================================================
# Tempo Agent — Environment Configuration
# Copy to .env and fill in values. Never commit .env to git.
# =============================================================================

# --- Backend (Elixir/Phoenix) ------------------------------------------------
SECRET_KEY_BASE=generate-with-mix-phx.gen.secret
PORT=4000
PHX_HOST=localhost
TEMPO_PORT=4000
DATA_DIR=data

# --- Dashboard (Angular) -----------------------------------------------------
DASHBOARD_PORT=4200

# --- Data Sources -------------------------------------------------------------

# Augment Code Analytics API (enterprise)
AUGMENT_API_URL=https://api.augmentcode.com
AUGMENT_API_TOKEN=

# GitHub Copilot Metrics API (planned)
COPILOT_API_TOKEN=
COPILOT_ORG=

# Claude / Anthropic Usage API (planned)
CLAUDE_API_KEY=

# --- Inter-Agent Message Queue (IAMQ) ----------------------------------------
IAMQ_HTTP_URL=http://127.0.0.1:18790
IAMQ_WS_URL=ws://127.0.0.1:18793/ws
IAMQ_AGENT_ID=tempo_agent
IAMQ_AGENT_NAME=Tempo
IAMQ_AGENT_EMOJI=⏱️
IAMQ_AGENT_DESC=AI tool analytics — aggregates usage from Augment Code, GitHub Copilot, and Claude
IAMQ_AGENT_CAPABILITIES=analytics,augment_code,github_copilot,claude_usage,dashboard,data_aggregation,usage_reporting
IAMQ_HEARTBEAT_MS=300000
IAMQ_POLL_MS=60000

# --- Agent Collaboration -----------------------------------------------------
LIBRARIAN_AGENT_WORKSPACE=

# --- User Profile (keep PII out of git) --------------------------------------
USER_DISPLAY_NAME=
USER_LOCATION=
USER_TIMEZONE=
USER_ORIGIN_COUNTRY=
USER_INTERESTS=

# --- Logging ------------------------------------------------------------------
TEMPO_LOG_LEVEL=INFO
